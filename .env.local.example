# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-key-here
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — NEVER expose to the browser or commit to git
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-key-here

# Optional — encrypts credential backups when Vault decrypt is unavailable
# CREDENTIAL_ENCRYPTION_KEY=your-long-random-string

# Stripe Connect — profit payouts to debit card / bank (server-only)
# STRIPE_SECRET_KEY=sk_test_...

# TikTok Shop webhooks (server-only, optional for local dev)
TIKTOK_WEBHOOK_CLIENT_SECRET=your-tiktok-app-client-secret

# TikTok Shop Open API (server-only — required for live listing / image sync)
# TIKTOK_APP_KEY=your_app_key
# TIKTOK_APP_SECRET=your_app_secret

# Force simulated TikTok Shop publishing even when user credentials exist
# TIKTOK_SHOP_SIMULATE_PUBLISH=true

# Inngest background jobs (optional — order fulfillment queue)
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key
